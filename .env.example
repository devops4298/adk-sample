# ADK Master Example - Environment Configuration
# Copy this to .env and fill in your values

# ============================
# GOOGLE CLOUD (Required)
# ============================
GOOGLE_CLOUD_PROJECT=your-project-id
GOOGLE_CLOUD_LOCATION=us-central1

# ============================
# MODELS (Optional)
# ============================
# MAIN_MODEL=gemini-2.0-flash
# WORKER_MODEL=gemini-2.0-flash

# ============================
# DEBUG (Optional)
# ============================
DEBUG_MODE=true

# ============================
# ARIZE OBSERVABILITY (Level 9)
# ============================
# Get credentials from https://app.arize.com
# ARIZE_SPACE_ID=your-space-id
# ARIZE_API_KEY=your-api-key
# ARIZE_PROJECT_NAME=adk-advanced-example

# ============================
# FIRESTORE PERSISTENCE (Level 10)
# ============================
# Enable session/state persistence
# ENABLE_FIRESTORE=true
# FIRESTORE_DATABASE=(default)

# ============================
# MEMORY BANK (Level 12)
# ============================
# Enable Vertex AI Memory Bank
# ENABLE_MEMORY_BANK=true

# ============================
# MCP SERVER (Level 13)
# ============================
# URL of your MCP server
# MCP_SERVER_URL=http://localhost:8080/mcp

# ============================
# A2A PROTOCOL (Level 11)
# ============================
# Port for A2A server
# A2A_PORT=10000
